{
  "name": "@agent-html/ahtml",
  "version": "0.1.0-alpha.4",
  "description": "Sanitized agent-html artifact CLI.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ahtml": "bin/ahtml.mjs"
  },
  "files": [
    "bin/",
    "src/config/",
    "src/engine/component-schema.ts",
    "src/engine/core.ts",
    "src/engine/generated/",
    "src/engine/render-config.ts",
    "src/engine/types.ts",
    "src/engine/parse/",
    "src/cli/",
    "!src/**/*.test.ts",
    "!src/engine/examples/",
    "tsconfig.json",
    "tsconfig.node.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "format:check:source": "prettier package.json tsconfig.json tsconfig.node.json eslint.config.js vitest.config.ts knip.json README.md \".github/workflows/*.yml\" \"src/**/*.{ts,mjs}\" \"!src/engine/generated/**\" \"scripts/**/*.mjs\" \"docs-web/content/**/*.mdx\" --check",
    "knip": "knip",
    "test": "vitest",
    "test:run": "vitest run",
    "docs:lint": "markdownlint-cli2",
    "docs:web:build": "npm --prefix docs-web run build",
    "docs:web:dev": "npm --prefix docs-web run dev",
    "docs:web:lint": "npm --prefix docs-web run lint",
    "docs:web:preview": "npm --prefix docs-web run start",
    "docs:web:check": "npm --prefix docs-web run types:check && npm run docs:web:lint && npm run docs:web:build",
    "agent": "node src/cli/index.mjs",
    "verify:pack": "node scripts/verify-packed-ahtml.mjs",
    "schema:prompt": "node scripts/generate-component-schema-prompt.mjs",
    "ci:check": "npm run format:check:source && npm run lint && npm run knip && npm run test:run && npm run build",
    "check": "npm run ci:check"
  },
  "dependencies": {
    "parse5": "^8.0.1",
    "typescript": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.2",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "knip": "^5.71.0",
    "markdownlint-cli2": "^0.19.1",
    "prettier": "^3.7.4",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.17"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sayhi-bzb/Agent-HTML.git"
  },
  "keywords": ["agent-html", "ahtml", "cli", "artifact", "shadcn"],
  "author": "",
  "bugs": {
    "url": "https://github.com/Sayhi-bzb/Agent-HTML/issues"
  },
  "homepage": "https://agent-html.pages.dev/docs"
}
