    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "knip": "^5.71.0",
    "markdownlint-cli2": "^0.19.1",
    "prettier": "^3.7.4",
