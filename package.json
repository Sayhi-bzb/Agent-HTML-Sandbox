    "lucide-react": "^1.14.0",
    "parse5": "^8.0.1",
    "radix-ui": "^1.4.3",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "typescript": "latest",
    "vite": "^6.3.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
