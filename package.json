{
  "name": "@agent-html/ahtml",
  "version": "0.1.0-alpha.9",
  "description": "Sanitized agent-html artifact CLI.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ahtml": "bin/ahtml.mjs"
  },
  "files": [
    "bin/",
    "src/config/",
    "src/engine/component-schema.ts",
    "src/engine/core.ts",
    "src/engine/generated/",
    "src/engine/render-config.ts",
    "src/engine/types.ts",
    "src/engine/parse/",
    "src/cli/",
    "!src/**/*.test.ts",
    "tsconfig.json",
    "tsconfig.node.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint .",
    "lint:cache": "eslint . --cache --cache-location .cache/eslint",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "format:check:source": "prettier package.json tsconfig.json tsconfig.node.json eslint.config.js vitest.config.ts knip.json README.md \".github/workflows/*.yml\" \".github/actions/**/*.yml\" \"src/**/*.{ts,mjs}\" \"!src/engine/generated/**\" \"scripts/**/*.mjs\" \"docs-web/content/**/*.mdx\" --check",
    "knip": "knip",
    "test": "vitest",
    "test:run": "vitest run",
    "docs:lint": "markdownlint-cli2",
    "docs:web:build": "npm --prefix docs-web run build",
    "docs:web:dev": "npm --prefix docs-web run dev",
    "docs:web:lint": "npm --prefix docs-web run lint",
    "docs:web:preview": "npm --prefix docs-web run start",
    "docs:web:check": "npm --prefix docs-web run types:check && npm run docs:web:lint && npm run docs:web:build",
    "agent": "node src/cli/index.mjs",
    "verify:pack": "node scripts/verify-packed-ahtml.mjs",
    "version:alpha": "node scripts/version-next-alpha.mjs",
    "dev:check": "npm run check:commit",
    "release:alpha": "npm run version:alpha",
    "release:metadata": "node scripts/release-metadata.mjs",
    "release:check": "npm run check:all && npm publish --access public --tag alpha --dry-run",
    "release:check:ci": "npm run check:ready",
    "release:tag": "node scripts/release-tag.mjs",
    "schema:prompt": "node scripts/generate-component-schema-prompt.mjs",
    "gitnexus:analyze": "npx gitnexus analyze --skip-agents-md",
    "gitnexus:analyze:force": "npx gitnexus analyze --force --skip-agents-md",
    "check:quick": "npm run format:check:source && npm run lint && npm run test:run",
    "check:commit": "npm run check:quick",
    "check:ready": "npm run check:quick && npm run knip && npm run build && npm run verify:pack && npm run docs:lint",
    "check:docs": "npm run docs:lint && npm run docs:web:check",
    "check:all": "npm run check:ready && npm run docs:web:check",
    "ci:check": "npm run check:ready",
    "check": "npm run check:ready"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "parse5": "^8.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "typescript": "latest",
    "vite": "^7.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.2",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "knip": "^5.71.0",
    "markdownlint-cli2": "^0.19.1",
    "prettier": "^3.7.4",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.17"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sayhi-bzb/Agent-HTML.git"
  },
  "keywords": [
    "agent-html",
    "ahtml",
    "cli",
    "artifact",
    "shadcn"
  ],
  "author": "",
  "bugs": {
    "url": "https://github.com/Sayhi-bzb/Agent-HTML/issues"
  },
  "homepage": "https://agent-html.pages.dev/docs"
}
