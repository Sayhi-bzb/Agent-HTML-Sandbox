{
  "name": "agent-html-sandbox",
  "private": true,
  "version": "0.0.0",
  "description": "Sanitized agent-html artifact CLI.",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "ahtml": "./bin/ahtml.mjs"
  },
  "files": [
    "bin/",
    "scripts/agent-html-cli-contract.mjs",
    "scripts/agent-html-cli-commands.mjs",
    "scripts/agent-html-cli.mjs",
    "scripts/agent-html-cli-schema.mjs",
    "scripts/agent-html-cli-validate.mjs",
    "scripts/inline-dist-index.mjs",
    "src/App.tsx",
    "src/main.tsx",
    "src/index.css",
    "src/vite-env.d.ts",
    "src/lib/",
    "src/components/ui/",
    "src/agent-html/component-schema.ts",
    "src/agent-html/generated/",
    "src/agent-html/render-config.ts",
    "src/agent-html/types.ts",
    "src/agent-html/parse/",
    "src/agent-html/renderer/",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/test/",
    "!src/agent-html/examples/",
    "index.html",
    "vite.config.ts",
    "tsconfig.json",
    "tsconfig.app.json",
    "README.md"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/inline-dist-index.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "knip": "knip",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "docs:lint": "markdownlint-cli2",
    "docs:web:build": "npm --prefix docs-web run build",
    "docs:web:dev": "npm --prefix docs-web run dev",
    "docs:web:lint": "npm --prefix docs-web run lint",
    "docs:web:preview": "npm --prefix docs-web run start",
    "agent": "node scripts/agent-html-cli.mjs",
    "verify:pack": "node scripts/verify-packed-ahtml.mjs",
    "schema:generate": "node scripts/generate-component-schema.mjs",
    "schema:check": "node scripts/generate-component-schema.mjs --check",
    "schema:prompt": "node scripts/generate-component-schema-prompt.mjs",
    "check": "npm run format:check && npm run lint && npm run knip && npm run test:run && npm run build"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^4.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "parse5": "^8.0.1",
    "radix-ui": "^1.4.3",
    "react": "latest",
    "react-dom": "latest",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "latest",
    "vite": "^6.3.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^27.3.0",
    "knip": "^5.71.0",
    "markdownlint-cli2": "^0.19.1",
    "prettier": "^3.7.4",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.0.17"
  }
}
