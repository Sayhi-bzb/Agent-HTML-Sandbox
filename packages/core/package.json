{
  "name": "@agent-html/core",
  "version": "0.2.0-alpha.1",
  "description": "Core contracts and sanitization for agent-html.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./src/core.ts",
      "default": "./index.mjs"
    }
  },
  "types": "./src/core.ts",
  "files": [
    "index.mjs",
    "src/",
    "!src/**/*.test.ts",
    "!src/examples/",
    "!src/schema-overlays.ts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "parse5": "^8.0.1",
    "typescript": "latest",
    "zod": "^4.4.3"
  },
  "keywords": [
    "agent-html",
    "core",
    "schema",
    "sanitize",
    "html"
  ]
}
