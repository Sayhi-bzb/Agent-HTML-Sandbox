{
  "name": "@agent-html/ahtml",
  "version": "0.1.0",
  "description": "AI-native HTML artifacts for replacing long Markdown outputs.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "ahtml": "bin/ahtml.mjs"
  },
  "files": [
    "bin/",
    "assets/ghost.svg",
    "src/config/",
    "src/cli/",
    "!src/cli/cli-test-helpers.ts",
    "!src/**/*.test.ts",
    "README.md"
  ],
  "scripts": {
    "agent": "node src/cli/index.mjs",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@agent-html/core": "^0.1.0",
    "@base-ui/react": "^1.0.0-beta.4",
    "@clack/prompts": "^1.4.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "parse5": "^8.0.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "latest",
    "vite": "^7.3.0"
  },
  "homepage": "https://agent-html.pages.dev/docs",
  "bugs": {
    "url": "https://github.com/Sayhi-bzb/Agent-HTML/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sayhi-bzb/Agent-HTML.git"
  },
  "keywords": [
    "agent-html",
    "ahtml",
    "cli",
    "artifact",
    "html-artifact",
    "agent-native",
    "markdown-alternative",
    "static-artifact",
    "shadcn"
  ]
}
