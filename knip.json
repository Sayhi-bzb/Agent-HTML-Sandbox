{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "packages/core/index.mjs",
    "packages/core/src/schema-overlays.ts",
    "packages/ahtml/src/cli/runtime-template/src/app.tsx",
    "packages/ahtml/src/cli/runtime-template/src/ssr.tsx"
  ],
  "ignoreBinaries": ["gitnexus"],
  "ignoreDependencies": [
    "@tailwindcss/vite",
    "@vitejs/plugin-react",
    "class-variance-authority",
    "clsx",
    "lucide-react",
    "radix-ui",
    "tailwind-merge",
    "tailwindcss",
    "tw-animate-css"
  ],
  "ignoreFiles": ["scripts/shadcn-test-fixtures/**/*"],
  "ignoreUnresolved": ["^@/components/ui/"],
  "project": [
    "packages/**/*.mjs",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "*.{ts,js}",
    "scripts/**/*.mjs"
  ],
  "rules": {
    "exports": "off"
  }
}
