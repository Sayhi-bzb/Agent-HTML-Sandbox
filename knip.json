{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "entry": [
    "src/engine/core.ts",
    "src/engine/schema-overlays.ts",
    "src/cli/runtime-template/src/app.tsx",
    "src/cli/runtime-template/src/ssr.tsx"
  ],
  "ignoreBinaries": ["gitnexus"],
  "ignoreDependencies": [
    "@tailwindcss/vite",
    "@vitejs/plugin-react",
    "class-variance-authority",
    "clsx",
    "lucide-react",
    "radix-ui",
    "tailwind-merge",
    "tailwindcss",
    "tw-animate-css"
  ],
  "ignoreFiles": ["src/cli/shadcn-template/vite-app/**/*"],
  "ignoreUnresolved": ["^@/components/ui/"],
  "project": [
    "src/**/*.mjs",
    "src/**/*.ts",
    "src/**/*.tsx",
    "*.{ts,js}",
    "scripts/**/*.mjs"
  ],
  "rules": {
    "exports": "off"
  }
}
